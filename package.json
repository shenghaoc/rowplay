{
  "name": "rowplay",
  "version": "0.1.0",
  "private": true,
  "description": "Concept2 logbook analytics + real-time workout replay, deployed on Cloudflare.",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build && node scripts/postbuild.mjs",
    "preview": "pnpm build && pnpm preview:ci",
    "preview:ci": "wrangler dev --ip 127.0.0.1 --port 8787",
    "deploy": "pnpm build && wrangler deploy",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "validate:locales": "node --experimental-strip-types scripts/validate-locales.mjs",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts --project webkit",
    "test:e2e:reuse": "E2E_REUSE_SERVER=1 playwright test",
    "db:migrate:local": "wrangler d1 migrations apply rowplay --local",
    "db:migrate": "wrangler d1 migrations apply rowplay --remote",
    "prepare": "vp config"
  },
  "dependencies": {
    "@fontsource/source-code-pro": "^5.2.7",
    "@fontsource/source-sans-3": "^5.2.9",
    "@lucide/svelte": "^1.17.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/svelte-virtual": "^3.13.26",
    "svelte-sonner": "^1.1.1",
    "tailwindcss": "^4.3.0",
    "temporal-polyfill": "~0.3.2",
    "three": "^0.184.0",
    "uplot": "^1.6.31"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.1",
    "@playwright/test": "1.60.0",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^25.9.1",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^4.1.8",
    "daisyui": "^5.5.20",
    "svelte": "^5.56.0",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "wrangler": "^4.95.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=26"
  },
  "packageManager": "pnpm@10.12.1"
}
