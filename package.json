{
  "name": "rowplay",
  "version": "0.1.0",
  "private": true,
  "description": "Concept2 logbook analytics + real-time workout replay, deployed on Cloudflare.",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build && node scripts/postbuild.mjs",
    "preview": "vp build && vp run preview:wrangler",
    "preview:wrangler": "wrangler dev --ip 127.0.0.1 --port 8787",
    "deploy": "vp build && wrangler deploy",
    "format": "vp fmt .",
    "format:check": "vp fmt --check .",
    "lint": "vp lint .",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check": "vp run format:check && vp lint . && vp run typecheck && vp test run && vp build",
    "validate:locales": "node --experimental-strip-types scripts/validate-locales.mjs",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:browser": "vp test run --config vitest.browser.config.ts",
    "test:browser:watch": "vp test --config vitest.browser.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts --project chromium",
    "test:e2e:reuse": "E2E_REUSE_SERVER=1 playwright test",
    "db:migrate:local": "wrangler d1 migrations apply rowplay --local",
    "db:migrate": "wrangler d1 migrations apply rowplay --remote",
    "prepare": "vp config"
  },
  "dependencies": {
    "@fontsource/source-code-pro": "^5.2.7",
    "@fontsource/source-sans-3": "^5.2.9",
    "@lucide/svelte": "^1.23.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/svelte-virtual": "^3.13.31",
    "svelte-sonner": "^1.1.1",
    "tailwindcss": "^4.3.0",
    "three": "^0.184.0",
    "uplot": "^1.6.31"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.1",
    "@playwright/test": "1.61.0",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.69.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^24.0.0",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^4.1.9",
    "daisyui": "^5.5.20",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.107.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
