# Copy to `.dev.vars` for local development (git-ignored).
#
# Demo mode works with zero config (`npm run dev`). For token auth, sync, KV, and
# D1 on the real Workers runtime, use `npm run preview` after filling SESSION_SECRET.

# Random string used to sign session cookies. Generate one, e.g.:
#   node -e "console.log(crypto.randomUUID()+crypto.randomUUID())"
SESSION_SECRET=""

PUBLIC_APP_URL="http://127.0.0.1:8787"
CONCEPT2_BASE_URL="https://log.concept2.com"

# Optional — only if you register a Concept2 developer app and enable OAuth login.
# Production BYOT deployment leaves these blank.
CONCEPT2_CLIENT_ID=""
CONCEPT2_CLIENT_SECRET=""
